---
import Footer from '@/components/footer.svelte';
import TextRotator from '@/components/text-rotator.svelte';
import BaseLayout from '@/layouts/base-layout.astro';
import {
	marketingSectionBodyClass,
	marketingSectionHeadingClass,
	marketingSectionOverlayClass,
	marketingSectionShellClass
} from '@/styles/marketing';
import { cn } from '@/utils';

const showcaseSections = [
	{
		id: 'vario',
		title: 'Vario',
		description: 'Modular robotics hardware supporting a wide variety of use cases.'
	},
	{
		id: 'sprocket',
		title: 'Sprocket',
		description:
			"The world's best IDE for creating MCU firmware, ROS 2 packages, high-level robot apps, and even initial hardware designs."
	}
] as const;

const baseSectionClass = cn(marketingSectionShellClass, 'flex min-h-svh pt-14');
---

<BaseLayout>
	<main class="scroller">
		<section class={cn(baseSectionClass, 'items-center justify-center')}>
			<div class="max-w-5xl px-6 text-center">
				<TextRotator
					client:load
					class={marketingSectionHeadingClass}
					interval={2500}
					words={['Allowing everyone to build their own', 'Improving your experience of building']}
				/>
				<h1
					class={cn(
						marketingSectionHeadingClass,
						'mt-2 bg-linear-to-r from-blue-400 via-blue-300 to-blue-200 bg-clip-text text-transparent'
					)}
				>
					robots and robot apps
				</h1>
				<p class={cn(marketingSectionBodyClass, 'mx-auto')}>
					A platform that simplifies every step of robotics development.
				</p>
			</div>
		</section>

		{
			showcaseSections.map((section) => (
				<section
					id={section.id}
					class={cn(baseSectionClass, 'items-center justify-start border-t border-border/10')}
				>
					<div class={marketingSectionOverlayClass} />
					<div class="relative max-w-5xl px-12 md:px-24 lg:px-32">
						<h2 class={marketingSectionHeadingClass}>{section.title}</h2>
						<p class={marketingSectionBodyClass}>{section.description}</p>
					</div>
				</section>
			))
		}

		<Footer />
	</main>
</BaseLayout>

<style is:global>
	html {
		scroll-snap-type: y mandatory;
	}

	.scroller > section,
	.scroller > footer {
		scroll-snap-align: start;
		scroll-snap-stop: always;
	}

	@media (pointer: coarse) {
		.scroller > section,
		.scroller > footer {
			scroll-snap-stop: normal;
		}
	}
</style>
